{
  "name": "tideye",
  "type": "module",
  "private": true,
  "version": "1.17.2",
  "scripts": {
    "build": "nuxt build",
    "db:ready": "pnpm run db:migrate && pnpm run db:seed",
    "dev": "pnpm run db:ready && (doppler run -- nuxt dev || nuxt dev)",
    "quality": "echo 'Turbo dependsOn handles lint + typecheck + format:check'",
    "db:migrate": "bash ../../tools/db-migrate.sh tideye-db --local --dir node_modules/@narduk-enterprises/narduk-nuxt-template-layer/drizzle --dir drizzle",
    "db:seed": "wrangler d1 execute tideye-db --local --file=node_modules/@narduk-enterprises/narduk-nuxt-template-layer/drizzle/seed.sql && wrangler d1 execute tideye-db --local --file=drizzle/seed-passages.sql",
    "db:seed:playback-preview": "PASSAGE_IMPORT_ALLOW_MISSING=1 PASSAGE_IMPORT_INCLUDE_TRAFFIC=0 node ../../tools/passage-playback-import-local-d1.mjs",
    "db:seed:passages-from-influx": "doppler run --project tideye --config prd -- node ../../tools/passage-seed-pipeline.mjs",
    "playback:export:passages": "doppler run --project tideye --config prd -- node ../../tools/passage-playback-export.mjs",
    "playback:import:d1-local": "PASSAGE_IMPORT_INCLUDE_TRAFFIC=0 node ../../tools/passage-playback-import-local-d1.mjs",
    "playback:publish:prod": "PASSAGE_IMPORT_REMOTE=1 PASSAGE_IMPORT_INCLUDE_TRAFFIC=0 PASSAGE_IMPORT_R2_BUCKET=tideye-playback PASSAGE_IMPORT_R2_PREFIX=passage-playback node ../../tools/passage-playback-import-local-d1.mjs",
    "db:reset": "bash ../../tools/db-migrate.sh tideye-db --local --dir node_modules/@narduk-enterprises/narduk-nuxt-template-layer/drizzle --dir drizzle --reset && pnpm run db:seed",
    "db:studio": "drizzle-kit studio",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "deploy": "nuxt build && wrangler deploy",
    "prelint": "test -f .nuxt/eslint.config.mjs || nuxt prepare",
    "lint": "eslint . --max-warnings 0",
    "test:e2e": "playwright test --project=web --config=../../playwright.config.ts",
    "format:check": "prettier --check \"**/*.{ts,mts,vue,js,mjs,json,yaml,yml,css,md}\" --ignore-path ../../.gitignore",
    "db:verify": "node node_modules/@narduk-enterprises/narduk-nuxt-template-layer/testing/verify-local-db.mjs ."
  },
  "dependencies": {
    "@narduk-enterprises/eslint-config": "^1.0.14",
    "@narduk-enterprises/narduk-nuxt-template-layer": "workspace:*",
    "@pinia/nuxt": "^0.11.3",
    "@signalk/client": "*",
    "@vueuse/core": "^13.0.0",
    "convert-units": "^2.3.4",
    "dayjs": "^1.11.13",
    "drizzle-orm": "^0.45.1",
    "nanoid": "^5.1.5",
    "nuxt": "^4.3.1",
    "pinia": "^3.0.3",
    "vue-draggable-plus": "^0.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250303.0",
    "@iconify-json/lucide": "^1.2.94",
    "@tailwindcss/vite": "^4.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.4",
    "nitro-cloudflare-dev": "^0.2.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.20.0"
  },
  "overrides": {
    "@cloudflare/unenv-preset": "2.12.1",
    "vite": "npm:rolldown-vite@7.3.1"
  },
  "volta": {
    "node": "22.22.0"
  }
}
